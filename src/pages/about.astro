---
import "../styles/home.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Sobre mí - Santiago Muñoz Villate</title>
    <style>
      .video-section {
        width: 100%;
        padding: 3rem 1rem;
        background: linear-gradient(135deg, #0f1724 0%, #1a2438 100%);
        display: flex;
        justify-content: center;
        align-items: center;
      }
      .video-wrapper {
        width: 100%;
        max-width: 700px;
      }
      .video-wrapper iframe {
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
    </style>
  </head>
  <body>
    <!-- Navigation -->
    <nav>
      <a href="/" class="site-name">Santiago Muñoz Villate</a>
    </nav>

    <!-- About Me -->
    <section class="about-section">
      <div class="about-content">
        <h2 class="about-title">Sobre mí</h2>
        <p class="about-text">
          Hola, soy Santiago Muñoz Villate, estudiante de Ingeniería de sistemas.
          Comparto proyectos y aprendizajes sobre desarrollo web y tecnología.
        </p>
      </div>
    </section>

    <!-- YouTube Video Section -->
    <section class="video-section">
      <div class="video-wrapper">
        <iframe 
          src="https://www.youtube.com/embed/dQw4w9WgXcQ?rel=0&modestbranding=1" 
          allowfullscreen="">
        </iframe>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="footer-content">
        <div class="footer-text">
          © 2026 Santiago Muñoz Villate. All rights reserved. • <a
            href="#"
            class="footer-link">Privacy Policy</a
          > • <a href="#" class="footer-link">Terms of Service</a> • <a
            href="#"
            class="footer-link">Sitemap</a
          >
        </div>
        <a href="https://github.com/tomcomtang/astro-cartoon-portfolio" class="footer-github">Star this project on Github</a>
      </div>
    </footer>
  </body>
</html>

